{
  "name": "simnode",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build --clean && npm run build:pkg --workspaces && tsc --build",
    "build:pkg": "bun run --filter './packages/*' --sequential build:pkg",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
