{
  "name": "@crashlab/core",
  "version": "0.1.6",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "crashlab": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc --build tsconfig.json --force",
    "clean": "rimraf dist",
    "prepack": "npm run build",
    "build:pkg": "tsup && tsc --build tsconfig.json --force"
  },
  "dependencies": {
    "@crashlab/clock": "0.1.6",
    "@crashlab/filesystem": "0.1.6",
    "@crashlab/http-proxy": "0.1.6",
    "@crashlab/random": "0.1.6",
    "@crashlab/scheduler": "0.1.6",
    "@crashlab/tcp": "0.1.6"
  },
  "peerDependencies": {
    "@crashlab/mongo": ">=0.1.0",
    "@crashlab/pg-mock": ">=0.1.0",
    "@crashlab/redis-mock": ">=0.1.0",
    "mongodb-memory-server": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "@crashlab/mongo": {
      "optional": true
    },
    "@crashlab/pg-mock": {
      "optional": true
    },
    "@crashlab/redis-mock": {
      "optional": true
    },
    "mongodb-memory-server": {
      "optional": true
    }
  }
}
