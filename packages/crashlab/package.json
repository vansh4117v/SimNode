{
  "name": "crashlab",
  "version": "1.0.0",
  "license": "MIT",
  "keywords": [
    "crashlab",
    "simulation",
    "deterministic",
    "testing",
    "race-conditions",
    "nodejs",
    "virtual-clock",
    "fault-injection"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "crashlab": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc --build tsconfig.json --force",
    "clean": "rimraf dist",
    "prepack": "npm run build",
    "build:pkg": "tsup && tsc --build tsconfig.json --force"
  },
  "dependencies": {
    "@crashlab/core": "1.0.0",
    "@crashlab/mongo": "1.0.0",
    "@crashlab/pg-mock": "1.0.0",
    "@crashlab/redis-mock": "1.0.0",
    "mongodb-memory-server": "^10.0.0"
  }
}
